<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
  <xs:element name="courses">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="course" minOccurs="0" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="Cno" type="xs:string"/>
              <xs:element name="Cnm" type="xs:string"/>
              <xs:element name="Ctm" type="xs:integer" minOccurs="0"/>
              <xs:element name="Cpt" type="xs:decimal"/>
              <xs:element name="Tec" type="xs:string"/>
              <xs:element name="Pla" type="xs:string"/>
              <xs:element name="Share">
                <xs:simpleType>
                  <xs:restriction base="xs:string">
                    <xs:enumeration value="Y"/><xs:enumeration value="N"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
